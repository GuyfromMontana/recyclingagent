{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/vapi/save-callback",
      "dest": "/api/vapi/save-callback.js"
    },
    {
      "src": "/api/vapi/get-caller-info",
      "dest": "/api/vapi/get-caller-info.js"
    },
    {
      "src": "/api/vapi/search-faqs",
      "dest": "/api/vapi/search-faqs.js"
    }
  ]
}
